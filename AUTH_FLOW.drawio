          <mxGeometry x="416" y="1404" width="318" height="60" as="geometry" />
        </mxCell>

        <!-- Create tenant MSAL client -->
        <mxCell id="n_create_tenant" value="Create PublicClientApplication&#xa;(authority = /{tenant_id})&#xa;Sharing same token_cache object" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="422" y="1536" width="306" height="80" as="geometry" />
        </mxCell>

        <!-- Find account in shared cache -->
        <mxCell id="n_find" value="Find account in shared cache&#xa;(match sso_username + realm = tenant_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="422" y="1690" width="306" height="60" as="geometry" />
        </mxCell>

        <!-- acquire_token_silent (first attempt) -->
        <mxCell id="n_silent" value="acquire_token_silent()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="455" y="1822" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Token acquired? (first attempt) -->
        <mxCell id="n_silent_q" value="Token acquired?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="452" y="1940" width="246" height="80" as="geometry" />
        </mxCell>

        <!-- acquire_token_silent with force_refresh -->
        <mxCell id="n_force_refresh" value="acquire_token_silent&#xa;(force_refresh = True)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="795" y="1940" width="250" height="60" as="geometry" />
        </mxCell>

        <!-- Token acquired? (second attempt) -->
        <mxCell id="n_force_q" value="Token acquired?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="798" y="2074" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Auth error: no token -->
        <mxCell id="n_err1" value="Write tenant auth_error file&#xa;Skip to next tenant" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1120" y="2079" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Decode JWT -->
        <mxCell id="n_decode" value="Decode JWT payload (Base64)&#xa;Read  tid  claim (without verifying signature)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="422" y="2214" width="306" height="60" as="geometry" />
        </mxCell>

        <!-- tid == tenant_id? -->
        <mxCell id="n_tid_q" value="tid == requested tenant_id?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="447" y="2348" width="256" height="80" as="geometry" />
        </mxCell>

        <!-- tid mismatch error -->
        <mxCell id="n_tid_err" value="Write auth_error file&#xa;(tid mismatch)&#xa;Skip to next tenant" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="795" y="2338" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- Token validated -->
