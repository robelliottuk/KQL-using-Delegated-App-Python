          <mxGeometry x="485" y="44" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- FORCE_FRESH_AUTH decision -->
        <mxCell id="n_force" value="FORCE_FRESH_AUTH_EACH_RUN?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="452" y="144" width="246" height="80" as="geometry" />
        </mxCell>

        <!-- Delete cache file -->
