          <mxGeometry x="795" y="149" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Load token cache -->
        <mxCell id="n_load" value="Load SerializableTokenCache into memory&#xa;(empty if FORCE mode or no cache file)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="437" y="304" width="276" height="60" as="geometry" />
        </mxCell>

        <!-- ── Phase 2 label ─────────────────────────────────────────────── -->
        <mxCell id="ph2_label" value="PHASE 2 — Initial SSO Login  (/organizations authority)" style="text;html=1;strokeColor=#82b366;fillColor=#e8f5e9;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="40" y="434" width="380" height="28" as="geometry" />
        </mxCell>

        <!-- Create SSO PublicClientApp -->
        <mxCell id="n_create_sso" value="Create PublicClientApplication&#xa;(authority = /organizations)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="437" y="454" width="276" height="60" as="geometry" />
        </mxCell>

        <!-- Cached SSO account? -->
        <mxCell id="n_cached_q" value="Cached SSO account&#xa;in MSAL cache?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="452" y="582" width="246" height="80" as="geometry" />
        </mxCell>

        <!-- Use cached account -->
        <mxCell id="n_use_cached" value="Use cached account&#xa;(no browser prompt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="795" y="587" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Interactive browser login -->
        <mxCell id="n_interactive" value="acquire_token_interactive()&#xa;Browser sign-in, port 8400&#xa;prompt = select_account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="432" y="734" width="286" height="80" as="geometry" />
        </mxCell>

        <!-- Access token returned? -->
        <mxCell id="n_token_q" value="Access token returned?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="452" y="886" width="246" height="80" as="geometry" />
        </mxCell>

        <!-- SSO failure -->
        <mxCell id="n_sso_error" value="Write sso_error.txt&#xa;SystemExit(1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="795" y="891" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Extract username -->
        <mxCell id="n_extract" value="Extract preferred_username&#xa;from id_token_claims" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="432" y="1040" width="286" height="60" as="geometry" />
        </mxCell>

        <!-- Save token cache -->
        <mxCell id="n_save" value="Save token cache to disk&#xa;(skipped if FORCE mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="437" y="1170" width="276" height="60" as="geometry" />
        </mxCell>

        <!-- Set sso_username (merge point) -->
