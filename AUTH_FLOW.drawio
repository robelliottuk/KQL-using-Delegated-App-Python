          <mxGeometry x="462" y="1300" width="226" height="50" as="geometry" />
        </mxCell>

        <!-- ── Phase 3 label ─────────────────────────────────────────────── -->
        <mxCell id="ph3_label" value="PHASE 3 — Per-Tenant Token Acquisition  (repeats for each tenant)" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e5f5;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;fontColor=#4a148c;" vertex="1" parent="1">
          <mxGeometry x="40" y="1384" width="420" height="28" as="geometry" />
        </mxCell>

        <!-- Tenant loop entry -->
