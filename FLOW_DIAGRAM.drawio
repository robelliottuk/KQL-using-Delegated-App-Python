          <mxGeometry x="5620" y="10" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="Y" value="POST KQL to Graph security/runHuntingQuery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
