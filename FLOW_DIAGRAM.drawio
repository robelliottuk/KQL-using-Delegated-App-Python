  <diagram id="appFlow" name="App Flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="A" value="Start script" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="B" value="Create output folder and timestamped run summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="C" value="FORCE_FRESH_AUTH_EACH_RUN?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="700" y="30" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="D" value="Delete local token cache file if present" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="980" y="10" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="E" value="Keep existing token cache file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="980" y="90" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="F" value="Load MSAL SerializableTokenCache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1320" y="50" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="G" value="Create PublicClientApplication (/organizations)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1650" y="50" width="330" height="60" as="geometry" />
        </mxCell>
        <mxCell id="H" value="Cached SSO account available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="2040" y="40" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="I" value="Use cached SSO account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="2340" y="10" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="J" value="Interactive sign-in (localhost:8400)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="2340" y="100" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="K" value="Access token returned?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="2640" y="90" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="L" value="Write SSO error file and exit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="2880" y="20" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="M" value="Extract username from id_token_claims" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="2880" y="110" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="N" value="Set authenticated username" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="3200" y="70" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="O" value="Loop through each tenant in TENANTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="3500" y="70" width="280" height="60" as="geometry" />
        </mxCell>
